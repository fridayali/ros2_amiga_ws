<?xml version="1.0" ?>
<robot name="amiga" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ==================== Robot Dimensions ==================== -->
  <xacro:property name="base_length" value="1.88"/>
  <xacro:property name="base_height" value="0.7"/>
  <xacro:property name="base_width"  value="1.52"/>
  <xacro:property name="wheel_radius" value="0.272"/>
  <xacro:property name="wheel_width"  value="0.162"/>

  <!-- ==================== Inertia Macros ==================== -->
  <xacro:macro name="box_inertia" params="m x y z o_xyz o_rpy">
    <inertial>
      <origin xyz="${o_xyz}" rpy="${o_rpy}"/>
      <mass value="${m}"/>
      <inertia ixx="${m*(y*y+z*z)/12}" ixy="0" ixz="0"
               iyy="${m*(x*x+z*z)/12}" iyz="0"
               izz="${m*(x*x+y*y)/12}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r h o_xyz o_rpy">
    <inertial>
      <origin xyz="${o_xyz}" rpy="${o_rpy}"/>
      <mass value="${m}"/>
      <inertia ixx="${m*(3*r*r+h*h)/12}" ixy="0" ixz="0"
               iyy="${m*(3*r*r+h*h)/12}" iyz="0"
               izz="${m*r*r/2}"/>
    </inertial>
  </xacro:macro>

  <!-- ==================== Base Link ==================== -->
  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="package://amiga_description/meshes/base_robot_amiga.dae" scale="1 1 1"/>
      </geometry>
      <origin rpy="0 0 ${pi}" xyz="0 0 0"/>
    </visual>
    <xacro:box_inertia m="100" x="${base_length}" y="${base_width}" z="${base_height}"
                       o_xyz="0 0 ${base_height/2}" o_rpy="0 0 0"/>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0.55"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
  </link>

  <!-- ==================== Wheels ==================== -->
  <xacro:macro name="wheel" params="name parent xyz rpy axis">
    <link name="${name}">
      <visual>
        <geometry>
          <mesh filename="package://amiga_description/meshes/wheel.dae" scale="1 1 1"/>
        </geometry>
        <origin rpy="${rpy}" xyz="0 0 0"/>
      </visual>
      <xacro:cylinder_inertia m="10" r="${wheel_radius}" h="${wheel_width}"
                               o_xyz="0 0 0" o_rpy="${pi/2} 0 0"/>
      <collision>
        <geometry>
          <cylinder length="${wheel_width}" radius="${wheel_radius}"/>
        </geometry>
        <origin rpy="${pi/2} 0 0" xyz="0 0 0"/>
      </collision>
    </link>
    <joint name="${name}_joint" type="continuous">
      <parent link="${parent}"/>
      <child link="${name}"/>
      <origin rpy="0 0 0" xyz="${xyz}"/>
      <axis xyz="${axis}"/>
    </joint>
  </xacro:macro>

  <xacro:wheel name="front_left_wheel"  parent="base_link" xyz=" 0.60468  0.57165 0.27" rpy="0 0 ${pi}" axis="0 1 0"/>
  <xacro:wheel name="front_right_wheel" parent="base_link" xyz=" 0.60468 -0.57165 0.27" rpy="0 0 0"     axis="0 1 0"/>
  <xacro:wheel name="rear_left_wheel"   parent="base_link" xyz="-0.60468  0.57165 0.27" rpy="0 0 ${pi}" axis="0 1 0"/>
  <xacro:wheel name="rear_right_wheel"  parent="base_link" xyz="-0.60468 -0.57165 0.27" rpy="0 0 0"     axis="0 1 0"/>

  <!-- ==================== IMU Link ==================== -->
  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin rpy="0 0 0" xyz="0 0 0.3"/>
  </joint>

  <!-- ==================== GPS Link ==================== -->
  <link name="gps_link"/>
  <joint name="gps_joint" type="fixed">
    <parent link="base_link"/>
    <child link="gps_link"/>
    <origin rpy="0 0 0" xyz="0 0 0.8"/>
  </joint>

  <!-- ==================== Laser Link ==================== -->
  <link name="laser_link"/>
  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_link"/>
    <origin rpy="0 0 0" xyz="0.5 0 0.4"/>
  </joint>

</robot>
